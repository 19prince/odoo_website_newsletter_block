<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ============================================================
     1. Snippet template body
     ============================================================ -->
<template id="s_newsletter_block" name="Newsletter Block">
    <!-- data-list-id on section: builder writes the selected list ID here via data-snippet attr.
         js_subscribe on inner div: public widget binds here.
         _getListId() traverses UP from .js_subscribe to [data-snippet=s_newsletter_block]
         to read data-list-id — so those must be on different elements. -->
    <section class="s_newsletter_block o_cc o_cc1 py-5"
             data-name="Newsletter Block"
             data-list-id="0">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="bg-light rounded-4 shadow p-4 p-lg-5">
                        <!-- Headline — EDIT-01 -->
                        <h2 class="fw-bold mb-2">Enjoying this? Get the next one in your inbox.</h2>
                        <!-- Body text — EDIT-02 -->
                        <p class="text-muted mb-4">I email when I publish something new. Usually 2 to 4 emails a month. Unsubscribe anytime.</p>
                        <!-- js_subscribe: public widget binds here.
                             data-list-id mirrors the section value — fallback for
                             _getListId() when closest('[data-snippet=...]') fails
                             (missing ] in Odoo 18 minified bundle).
                             Email input is DOM-first so widget reads subscription_type='email'.
                             Bootstrap order-md-* restores visual order: name | email | button. -->
                        <div class="js_subscribe" data-list-id="0">
                            <!-- Success state — EDIT-04 -->
                            <div class="js_subscribed_wrap d-none">
                                <p class="h4-fs text-success">
                                    <i class="fa fa-check-circle-o" role="img"/>
                                    Thanks for subscribing!
                                </p>
                            </div>
                            <!-- Form state — FORM-01 -->
                            <div class="js_subscribe_wrap">
                                <div class="row g-2 align-items-center">
                                    <!-- Email first in DOM: widget reads name attr of first input
                                         → subscription_type='email'. Visual order via order-md-2. -->
                                    <div class="col-12 col-md order-md-2">
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-end-0">
                                                <i class="fa fa-envelope text-muted"/>
                                            </span>
                                            <input type="email"
                                                   name="email"
                                                   class="js_subscribe_value form-control border-start-0"
                                                   placeholder="Your email"/>
                                        </div>
                                    </div>
                                    <!-- Name second in DOM, displayed first via order-md-1. -->
                                    <div class="col-12 col-md order-md-1">
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-end-0">
                                                <i class="fa fa-user text-muted"/>
                                            </span>
                                            <input type="text"
                                                   name="name"
                                                   class="form-control border-start-0"
                                                   placeholder="Your name"/>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-auto order-md-3">
                                        <a role="button" href="#"
                                           class="btn btn-dark rounded-pill px-4 w-100 js_subscribe_btn o_submit">
                                            Join my list
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <!-- Sub-caption — EDIT-03 -->
                            <p class="small text-muted mt-2 mb-0">
                                Join 1000+ readers. Unsubscribe anytime.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</template>

<!-- ============================================================
     2. Sidebar registration (SNIP-01, SNIP-02)
     website_mass_mailing replaces mass_mailing_newsletter_block_hook with a
     real <t t-snippet> element, so we XPath the replacement, not the hook.
     t-forbid-sanitize="form" — prevents HTML sanitizer from stripping
     input and button elements on page save (SNIP-02).
     ============================================================ -->
<template id="snippets" inherit_id="website.snippets">
    <!-- XPath to snippet-group declaration (stable in base view, never replaced)
         rather than the hook id (replaced by website_mass_mailing at render time). -->
    <xpath expr="//t[@snippet-group='contact_and_forms']" position="after">
        <t t-snippet="odoo_website_newsletter_block.s_newsletter_block"
           string="Newsletter Block"
           t-forbid-sanitize="form"
           group="contact_and_forms"
           t-thumbnail="/website/static/src/img/snippets_thumbs/s_website_form.svg">
            <keywords>newsletter, subscribe, signup, email, form, updates</keywords>
        </t>
    </xpath>
</template>


</odoo>
